---
/**
 * Branded placeholder shown wherever a real photo hasn't been added yet
 * (spec marks these ‹PLACEHOLDER›). Blush field, paisley outline, pearl
 * dots — quietly on-brand rather than a grey box.
 */
interface Props {
  ratio?: string;
  label?: string;
  class?: string;
}
const { ratio = '4/3', label, class: className = '' } = Astro.props;
---

<div class={`img-ph ${className}`} style={`aspect-ratio: ${ratio};`} role="img" aria-label={label ?? 'Photo coming soon'}>
  <svg viewBox="0 0 120 120" width="88" height="88" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path
      d="M60 12c22 0 38 16.5 38 37 0 19.8-15.2 35-34.5 35C48 84 36 73.2 36 59.5 36 48.6 44.6 40 55.3 40c8.4 0 14.6 6 14.6 13.6 0 6-4.4 10.4-10 10.4"
      stroke="#E66F67"
      stroke-width="3"
      stroke-linecap="round"
      opacity="0.85"
    />
    <circle cx="30" cy="96" r="3.5" fill="#E66F67" opacity="0.5" />
    <circle cx="45" cy="102" r="3.5" fill="#E66F67" opacity="0.65" />
    <circle cx="60" cy="105" r="3.5" fill="#E66F67" opacity="0.8" />
    <circle cx="75" cy="102" r="3.5" fill="#E66F67" opacity="0.65" />
    <circle cx="90" cy="96" r="3.5" fill="#E66F67" opacity="0.5" />
  </svg>
  {label && <span class="img-ph__label">{label}</span>}
</div>

<style>
  .img-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    width: 100%;
    background:
      radial-gradient(120% 90% at 20% 10%, rgba(230, 111, 103, 0.10), transparent 55%),
      var(--blush);
    border-radius: inherit;
  }

  .img-ph__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--coral-deep);
    opacity: 0.75;
    text-align: center;
    padding-inline: var(--space-4);
  }
</style>
