---
import type { CollectionEntry } from 'astro:content';
import CmsImage from './CmsImage.astro';

interface Props {
  branch: CollectionEntry<'branches'>;
  revealDelay?: number;
}
const { branch, revealDelay = 0 } = Astro.props;
const { data } = branch;
const courseNames = data.timings.map((t) => t.course.split('(')[0].trim());
const uniqueCourses = [...new Set(courseNames)];
---

<a href={`/branches/${branch.id}`} class="card branch-card reveal" data-reveal-delay={revealDelay || undefined}>
  <div class="branch-card__media">
    <CmsImage
      src={data.cover || data.photos[0]}
      alt={data.coverAlt ?? `${data.name} branch`}
      ratio="16/10"
      sizes="(max-width: 640px) 100vw, (max-width: 960px) 50vw, 25vw"
      placeholderLabel={data.online ? 'Live online classes' : `${data.name} studio`}
    />
  </div>
  <div class="card__body">
    <p class="branch-card__locality">{data.online ? 'Pan-India & abroad' : 'Jaipur'}</p>
    <h3>{data.name}</h3>
    <p class="branch-card__courses">{uniqueCourses.join(' · ')}</p>
    <span class="branch-card__link">View branch →</span>
  </div>
</a>

<style>
  .branch-card {
    display: block;
    text-decoration: none;
    color: var(--ink);
  }

  .branch-card__media {
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    overflow: hidden;
  }

  .branch-card__locality {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--coral-deep);
    margin-bottom: var(--space-1);
  }

  .branch-card h3 {
    margin-bottom: var(--space-2);
  }

  .branch-card__courses {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
  }

  .branch-card__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--coral-deep);
  }
</style>
