---
/**
 * Lazy YouTube/Vimeo embed with a lightweight facade (spec §7):
 * only a poster + play button load initially; the iframe loads on click,
 * so video never slows first paint.
 */
interface Props {
  url: string;
  title?: string;
}
const { url, title = 'Watch video' } = Astro.props;

function parseVideo(u: string): { embed: string; poster?: string } | null {
  const yt = u.match(
    /(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([\w-]{11})/
  );
  if (yt) {
    return {
      embed: `https://www.youtube-nocookie.com/embed/${yt[1]}?autoplay=1&rel=0`,
      poster: `https://i.ytimg.com/vi/${yt[1]}/hqdefault.jpg`,
    };
  }
  const vimeo = u.match(/vimeo\.com\/(\d+)/);
  if (vimeo) {
    return { embed: `https://player.vimeo.com/video/${vimeo[1]}?autoplay=1` };
  }
  return null;
}

const video = parseVideo(url);
---

{video && (
  <div class="yt-facade" data-embed={video.embed}>
    {video.poster ? (
      <img src={video.poster} alt="" loading="lazy" decoding="async" />
    ) : (
      <div class="yt-facade__blank" aria-hidden="true"></div>
    )}
    <button class="yt-facade__play" aria-label={`Play: ${title}`}>
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M8 5.5v13l11-6.5-11-6.5Z" />
      </svg>
    </button>
  </div>
)}

<style>
  .yt-facade {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--ink);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .yt-facade img,
  .yt-facade__blank {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }

  .yt-facade__blank {
    background:
      radial-gradient(100% 100% at 30% 20%, rgba(230, 111, 103, 0.35), transparent 60%),
      var(--ink);
  }

  .yt-facade__play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 4.25rem;
    height: 4.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    background: var(--coral);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 8px 30px -6px rgba(26, 26, 26, 0.5);
    transition: transform 0.25s var(--ease), background 0.25s var(--ease);
  }

  .yt-facade__play:hover {
    background: var(--coral-deep);
    transform: scale(1.08);
  }

  .yt-facade :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.yt-facade').forEach((el) => {
    el.querySelector('.yt-facade__play')?.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.src = el.dataset.embed ?? '';
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.title = 'Video player';
      el.innerHTML = '';
      el.appendChild(iframe);
    });
  });
</script>
