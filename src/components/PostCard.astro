---
import type { CollectionEntry } from 'astro:content';
import CmsImage from './CmsImage.astro';
import { formatDate } from '../lib/site';

interface Props {
  post: CollectionEntry<'blog'>;
  revealDelay?: number;
}
const { post, revealDelay = 0 } = Astro.props;
const { data } = post;
---

<article class="card post-card reveal" data-reveal-delay={revealDelay || undefined}>
  <a href={`/blog/${post.id}`} class="post-card__media" tabindex="-1" aria-hidden="true">
    <CmsImage
      src={data.cover}
      alt={data.coverAlt ?? ''}
      ratio="16/9"
      sizes="(max-width: 640px) 100vw, (max-width: 960px) 50vw, 33vw"
      placeholderLabel={data.category}
    />
  </a>
  <div class="card__body">
    <p class="post-card__meta">
      <span class="chip">{data.category}</span>
      <time datetime={data.date.toISOString().split('T')[0]}>{formatDate(data.date)}</time>
    </p>
    <h3><a href={`/blog/${post.id}`}>{data.title}</a></h3>
    <p class="post-card__excerpt">{data.excerpt}</p>
  </div>
</article>

<style>
  .post-card__media {
    display: block;
    overflow: hidden;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
  }

  .post-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .post-card h3 a {
    color: var(--ink);
    text-decoration: none;
  }

  .post-card h3 a:hover {
    color: var(--coral-deep);
  }

  .post-card__excerpt {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
