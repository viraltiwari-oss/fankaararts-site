---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { waLink } from '../lib/site';

const nav = [
  { label: 'About', href: '/about' },
  { label: 'Branches', href: '/branches' },
  { label: 'Courses', href: '/courses' },
  { label: 'Workshops', href: '/workshops' },
  { label: 'Events', href: '/events' },
  { label: 'Accomplishments', href: '/accomplishments' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === current || (href !== '/' && current.startsWith(href));
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label="Fankaar Institute of Performing Arts — home">
      <Image src={logo} alt="Fankaar Institute of Performing Arts" height={96} densities={[1, 2]} loading="eager" class="site-header__logo" />
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={waLink()} class="btn btn--primary site-header__cta" data-track="whatsapp" target="_blank" rel="noopener">
      Enquire
    </a>

    <button
      class="site-header__burger"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile menu lives OUTSIDE <header>: the header's backdrop-filter would
     otherwise trap this position:fixed panel inside the header box (iOS bug). -->
<div class="mobile-menu" id="mobile-menu" hidden>
  <nav aria-label="Mobile">
    <ul>
      <li><a href="/">Home</a></li>
      {nav.map((item) => (
        <li>
          <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        </li>
      ))}
      <li class="mobile-menu__cta">
        <a href={waLink()} class="btn btn--primary" data-track="whatsapp" target="_blank" rel="noopener">
          Enquire on WhatsApp
        </a>
      </li>
    </ul>
  </nav>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }

  .site-header.is-scrolled {
    border-bottom-color: var(--line);
    box-shadow: 0 2px 20px -8px rgba(26, 26, 26, 0.12);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    height: var(--header-h);
    transition: height 0.3s var(--ease);
  }

  .site-header.is-scrolled .site-header__inner {
    height: var(--header-h-condensed);
  }

  .site-header__brand {
    flex: none;
    display: flex;
    align-items: center;
  }

  .site-header__logo {
    width: auto;
    height: 3.1rem;
    transition: height 0.3s var(--ease);
  }

  .site-header.is-scrolled .site-header__logo {
    height: 2.4rem;
  }

  .site-header__nav {
    margin-left: auto;
  }

  .site-header__nav ul {
    display: flex;
    gap: clamp(0.9rem, 1.6vw, 1.6rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding-block: 0.4rem;
    border-bottom: 2px solid transparent;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
    white-space: nowrap;
  }

  .site-header__nav a:hover {
    color: var(--coral-deep);
  }

  .site-header__nav a[aria-current='page'] {
    color: var(--coral-deep);
    border-bottom-color: var(--coral);
  }

  .site-header__cta {
    flex: none;
    min-height: 2.6rem;
    padding: 0.45rem 1.3rem;
    font-size: var(--text-sm);
  }

  .site-header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    margin-left: auto;
    padding: 10px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .site-header__burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
  }

  .site-header__burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .site-header__burger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .site-header__burger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    padding-top: var(--header-h);
    background: var(--white);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    z-index: 95;
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: var(--space-5) var(--gutter) var(--space-8);
  }

  .mobile-menu li + li {
    border-top: 1px solid var(--line);
  }

  .mobile-menu a:not(.btn) {
    display: block;
    padding: 0.95rem 0.25rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
  }

  .mobile-menu a[aria-current='page'] {
    color: var(--coral-deep);
  }

  .mobile-menu__cta {
    padding-top: var(--space-5);
  }

  .mobile-menu__cta .btn {
    width: 100%;
  }

  @media (max-width: 1099px) {
    .site-header__nav,
    .site-header__cta {
      display: none;
    }

    .site-header__burger {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  // Condense on scroll
  let ticking = false;
  const onScroll = () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        header?.classList.toggle('is-scrolled', window.scrollY > 24);
        ticking = false;
      });
      ticking = true;
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    if (menu) {
      menu.hidden = open;
      menu.classList.toggle('is-open', !open);
      document.body.style.overflow = open ? '' : 'hidden';
    }
  });

  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      if (menu) {
        menu.hidden = true;
        menu.classList.remove('is-open');
      }
      document.body.style.overflow = '';
    })
  );
</script>
