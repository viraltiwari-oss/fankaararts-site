---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import { waLink, telLink, settings } from '../lib/site';
---

<BaseLayout
  title="Enrolment Enquiry | Fankaar Institute of Performing Arts, Jaipur"
  description="Enquire about Kathak, vocal, guitar or keyboard classes at Fankaar Institute, Jaipur. Fill the form or message us on WhatsApp — we reply the same day."
>
  <section class="band band--blush">
    <div class="container">
      <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Enquiry', path: '/enquiry' }]} />
      <div class="enquiry-intro">
        <div>
          <p class="eyebrow">Start here</p>
          <h1>Enrolment enquiry</h1>
          <p class="lead">
            Tell us a little about the student and what you'd like to learn.
            We'll reply the same day with the right course, branch and current
            fees. Prefer to chat? Message us on WhatsApp.
          </p>
          <div class="enquiry-intro__quick">
            <a href={waLink()} class="btn btn--primary" data-track="whatsapp" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.9-4.45 9.9-9.91A9.87 9.87 0 0 0 12.04 2Z"/></svg>
              WhatsApp us
            </a>
            <a href={telLink()} class="btn btn--ghost">Call +91 {settings.phone}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <div class="enquiry-layout">
        <div class="enquiry-layout__form reveal">
          <EnquiryForm />
        </div>
        <aside class="enquiry-layout__aside reveal">
          <div class="enquiry-aside">
            <h2>What happens next</h2>
            <ol class="enquiry-steps">
              <li><strong>You send this form.</strong> It reaches us by email and, if you like, opens WhatsApp pre-filled.</li>
              <li><strong>We reply the same day</strong> with course details, the nearest branch, current fees and batch timings.</li>
              <li><strong>You visit for a first class.</strong> Meet the guru, see the studio, decide with no pressure.</li>
            </ol>
            <p class="enquiry-aside__note">
              We only use your details to respond to this enquiry — never shared,
              never spammed. See our <a href="/privacy">privacy policy</a>.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .enquiry-intro {
    max-width: 46rem;
  }

  .enquiry-intro__quick {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .enquiry-layout {
    display: grid;
    gap: var(--space-7);
  }

  @media (min-width: 900px) {
    .enquiry-layout {
      grid-template-columns: 3fr 2fr;
      align-items: start;
    }
  }

  .enquiry-aside {
    background: var(--blush);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .enquiry-steps {
    padding-left: 1.2rem;
    margin: var(--space-4) 0;
  }

  .enquiry-steps li {
    margin-bottom: var(--space-3);
  }

  .enquiry-aside__note {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
  }
</style>
