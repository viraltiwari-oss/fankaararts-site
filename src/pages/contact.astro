---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import { settings, waLink, telLink, mailLink, mapEmbedUrl } from '../lib/site';
import PageHero from '../components/PageHero.astro';
import pages from '../data/pages.json';

const branches = (await getCollection('branches')).sort(
  (a, b) => a.data.order - b.data.order
);
const physical = branches.filter((b) => !b.data.online);
const { instagram, facebook, youtube } = settings.social;
---

<BaseLayout
  title="Contact Fankaar Institute — Phone, WhatsApp & Branches | Jaipur"
  description="Contact Fankaar Institute of Performing Arts, Jaipur. WhatsApp/phone 7976014592, email art.fankar@gmail.com. Addresses and maps for all four Jaipur branches."
>
  <PageHero
    eyebrow="Get in touch"
    title="Contact us"
    lead="The fastest way to reach us is WhatsApp — we usually reply within a few hours, every day."
    cover={pages.contact.cover}
    coverAlt={pages.contact.coverAlt}
    crumbs={[{ name: 'Home', path: '/' }, { name: 'Contact', path: '/contact' }]}
  />

  <section class="band band--blush">
    <div class="container">
      <div class="contact-methods">
        <a href={waLink()} class="contact-method" data-track="whatsapp" target="_blank" rel="noopener">
          <span class="contact-method__label">WhatsApp</span>
          <span class="contact-method__value">Chat now</span>
        </a>
        <a href={telLink()} class="contact-method">
          <span class="contact-method__label">Phone</span>
          <span class="contact-method__value">+91 {settings.phone}</span>
        </a>
        <a href={mailLink()} class="contact-method">
          <span class="contact-method__label">Email</span>
          <span class="contact-method__value">{settings.email}</span>
        </a>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <div class="contact-layout">
        <div class="reveal">
          <h2>Send an enquiry</h2>
          <EnquiryForm />
        </div>
        <aside class="reveal">
          <h2>Our branches</h2>
          <ul class="contact-branches">
            {physical.map((b) => (
              <li>
                <h3>{b.data.name}</h3>
                {b.data.address ? (
                  <p>{b.data.address}</p>
                ) : (
                  <p class="contact-branches__note">{b.data.addressNote}</p>
                )}
                <div class="contact-branches__links">
                  <a href={`/branches/${b.id}`}>Branch page</a>
                  {b.data.mapLink && (
                    <a href={b.data.mapLink} target="_blank" rel="noopener">Directions</a>
                  )}
                </div>
              </li>
            ))}
          </ul>

          <div class="contact-hours">
            <h3>Enquiry hours</h3>
            <p>{settings.hours}</p>
          </div>

          {(instagram || facebook || youtube) && (
            <div class="contact-social">
              <h3>Follow us</h3>
              <div class="contact-social__links">
                {instagram && <a href={instagram} target="_blank" rel="noopener">Instagram</a>}
                {facebook && <a href={facebook} target="_blank" rel="noopener">Facebook</a>}
                {youtube && <a href={youtube} target="_blank" rel="noopener">YouTube</a>}
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </section>

  <section class="band band--blush">
    <div class="container">
      <div class="section-head reveal">
        <h2>Find us on the map</h2>
      </div>
      <div class="contact-maps">
        {physical.filter((b) => b.data.mapQuery).map((b, i) => (
          <div class="contact-map reveal" data-reveal-delay={i % 2}>
            <iframe
              src={mapEmbedUrl(`Fankaar Institute of Performing Arts, ${b.data.mapQuery}`)}
              title={`Map — ${b.data.name}`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
            <p>{b.data.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-methods {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .contact-methods {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .contact-method {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-5);
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--ink);
    transition: box-shadow 0.25s var(--ease), transform 0.25s var(--ease);
  }

  .contact-method:hover {
    box-shadow: var(--shadow-card);
    transform: translateY(-3px);
    color: var(--ink);
  }

  .contact-method__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--coral-deep);
  }

  .contact-method__value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
  }

  .contact-layout {
    display: grid;
    gap: var(--space-7);
  }

  @media (min-width: 900px) {
    .contact-layout {
      grid-template-columns: 3fr 2fr;
      align-items: start;
    }
  }

  .contact-branches {
    list-style: none;
    margin: 0 0 var(--space-6);
    padding: 0;
  }

  .contact-branches li {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--line);
  }

  .contact-branches h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .contact-branches p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin-bottom: var(--space-2);
  }

  .contact-branches__note {
    font-style: italic;
  }

  .contact-branches__links {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .contact-hours,
  .contact-social {
    margin-top: var(--space-5);
  }

  .contact-hours h3,
  .contact-social h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .contact-social__links {
    display: flex;
    gap: var(--space-4);
    font-weight: 600;
  }

  .contact-maps {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }

  @media (min-width: 760px) {
    .contact-maps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .contact-map {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    background: var(--white);
  }

  .contact-map iframe {
    display: block;
    width: 100%;
    height: 16rem;
    border: 0;
  }

  .contact-map p {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    font-weight: 600;
  }
</style>
