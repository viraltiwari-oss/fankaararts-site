---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CmsImage from '../components/CmsImage.astro';
import StatStrip from '../components/StatStrip.astro';
import MotifDivider from '../components/MotifDivider.astro';
import BranchCard from '../components/BranchCard.astro';
import EventCard from '../components/EventCard.astro';
import WorkshopCard from '../components/WorkshopCard.astro';
import TestimonialQuote from '../components/TestimonialQuote.astro';
import CtaBand from '../components/CtaBand.astro';
import GhungrooStrand from '../components/GhungrooStrand.astro';
import home from '../data/home.json';
import { waLink, isUpcoming } from '../lib/site';

const courses = (await getCollection('courses')).sort(
  (a, b) => a.data.order - b.data.order
);
const branches = (await getCollection('branches')).sort(
  (a, b) => a.data.order - b.data.order
);
const events = (await getCollection('events'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const workshops = (await getCollection('workshops'))
  .filter((w) => isUpcoming(w.data.start, w.data.end))
  .sort((a, b) => a.data.start.getTime() - b.data.start.getTime())
  .slice(0, 3);
const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured)
);

const { hero, stats, intro } = home;
const hasMedia = Boolean(hero.videoUrl || hero.image);

const accomplishmentsTeaser = [
  { value: '3', label: 'CCRT scholarship awardees' },
  { value: '175+', label: 'students trained since inception' },
  { value: '3', label: 'affiliated examination boards' },
];
---

<BaseLayout
  title="Kathak & Music Classes in Jaipur | Fankaar Institute of Performing Arts"
  description="Fankaar Institute of Performing Arts, Jaipur — authentic Kathak & Hindustani classical music training for ages 6–70+. Four branches (Malviya Nagar, Tonk Road, Jagatpura, Nirman Nagar) + online classes. Enquire on WhatsApp."
>
  {/* ---------------- Hero (§4.1) ---------------- */}
  <section class:list={['hero', { 'hero--media': hasMedia }]}>
    {hero.videoUrl ? (
      <video
        class="hero__bg"
        src={hero.videoUrl}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      ></video>
    ) : hero.image ? (
      <div class="hero__bg">
        <CmsImage
          src={hero.image}
          alt=""
          ratio="16/9"
          widths={[640, 1024, 1600, 2048]}
          sizes="100vw"
          loading="eager"
        />
      </div>
    ) : (
      <div class="hero__motif" aria-hidden="true">
        <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M200 30c95 0 165 68 165 155 0 84-66 150-150 150-67 0-121-46-121-105 0-47 37-84 84-84 37 0 64 26 64 59 0 26-19 45-44 45"
            stroke="#E66F67"
            stroke-width="2.5"
            stroke-linecap="round"
            opacity="0.35"
          />
          <circle cx="84" cy="330" r="7" fill="#E66F67" opacity="0.25" />
          <circle cx="122" cy="352" r="7" fill="#E66F67" opacity="0.35" />
          <circle cx="163" cy="365" r="7" fill="#E66F67" opacity="0.45" />
          <circle cx="205" cy="369" r="7" fill="#E66F67" opacity="0.55" />
        </svg>
      </div>
    )}

    <div class="container hero__content">
      <p class="hero__eyebrow devanagari" lang="hi">नृत्य • संगीत</p>
      <h1 class="hero__title">
        Discover the <em class="brand">fankaar</em> within.
      </h1>
      <p class="hero__sub">{hero.subtext}</p>
      <div class="hero__actions">
        <a href={waLink()} class="btn btn--primary" data-track="whatsapp" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.9-4.45 9.9-9.91A9.87 9.87 0 0 0 12.04 2Z"/></svg>
          {hero.ctaPrimary.label}
        </a>
        <a href={hero.ctaSecondary.url} class:list={['btn', hasMedia ? 'btn--light' : 'btn--ghost']}>
          {hero.ctaSecondary.label}
        </a>
      </div>
    </div>
  </section>

  {/* ---------------- Trust strip ---------------- */}
  <section class="band band--trust" aria-label="Fankaar at a glance">
    <div class="container">
      <StatStrip stats={stats} />
    </div>
  </section>

  {/* ---------------- Intro ---------------- */}
  <section class="band band--blush">
    <div class="container">
      {intro.image ? (
        <div class="home-intro">
          <div class="home-intro__media reveal">
            <CmsImage
              src={intro.image}
              alt={intro.imageAlt ?? ''}
              ratio="4/5"
              sizes="(max-width: 860px) 100vw, 42vw"
            />
          </div>
          <div class="home-intro__text reveal">
            <p class="eyebrow">{intro.eyebrow}</p>
            <h2>{intro.heading}</h2>
            <p class="intro-text">{intro.text}</p>
            <a href={intro.ctaUrl} class="btn btn--ghost">{intro.ctaLabel}</a>
          </div>
        </div>
      ) : (
        <div class="container--narrow text-center reveal" style="margin-inline: auto;">
          <p class="eyebrow">{intro.eyebrow}</p>
          <h2>{intro.heading}</h2>
          <p class="intro-text">{intro.text}</p>
          <MotifDivider />
          <a href={intro.ctaUrl} class="btn btn--ghost">{intro.ctaLabel}</a>
        </div>
      )}
    </div>
  </section>

  {/* ---------------- Disciplines (§4.1) ---------------- */}
  <section class="band">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <p class="eyebrow">What we teach</p>
        <h2>Four disciplines, one standard</h2>
      </div>
      <div class="grid grid--4">
        {courses.map((course, i) => (
          <a href={`/courses#${course.id}`} class="card discipline-card reveal" data-reveal-delay={i || undefined}>
            <div class="discipline-card__media">
              <CmsImage
                src={course.data.image}
                alt={course.data.name}
                ratio="1/1"
                sizes="(max-width: 640px) 50vw, 25vw"
                placeholderLabel={course.data.name}
              />
            </div>
            <div class="card__body">
              <p class="discipline-card__discipline">{course.data.discipline}</p>
              <h3>{course.data.name}</h3>
              <p class="discipline-card__blurb">{course.data.short}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- Branches teaser ---------------- */}
  <section class="band band--blush">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Where we teach</p>
        <h2>Four studios across Jaipur — and online, everywhere</h2>
        <p class="lead">Malviya Nagar · Tonk Road · Jagatpura · Nirman Nagar · Online</p>
      </div>
      <div class="grid grid--3">
        {branches.map((b, i) => (
          <BranchCard branch={b} revealDelay={i % 3} />
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- Accomplishments teaser ---------------- */}
  <section class="band">
    <div class="container">
      <div class="acc-teaser reveal">
        <div>
          <p class="eyebrow">Proof, not promises</p>
          <h2>An institute that delivers</h2>
          <p class="lead">
            National scholarships, board examinations, full houses at recitals —
            our students' results speak for the training.
          </p>
          <a href="/accomplishments" class="btn btn--ghost">See our accomplishments</a>
        </div>
        <ul class="acc-teaser__list">
          {accomplishmentsTeaser.map((item) => (
            <li>
              <span class="acc-teaser__value">{item.value}</span>
              <span>{item.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* ---------------- Upcoming workshops (dynamic, hides if none) ---------------- */}
  {workshops.length > 0 && (
    <section class="band band--blush">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">Limited seats</p>
          <h2>Upcoming workshops</h2>
        </div>
        <div class="grid grid--3">
          {workshops.map((w, i) => (
            <WorkshopCard workshop={w} revealDelay={i} />
          ))}
        </div>
        <p class="text-center" style="margin-top: var(--space-6);">
          <a href="/workshops" class="btn btn--ghost">All workshops</a>
        </p>
      </div>
    </section>
  )}

  {/* ---------------- Testimonials (hides if none yet) ---------------- */}
  {testimonials.length > 0 && (
    <section class="band">
      <div class="container">
        <TestimonialQuote testimonial={testimonials[0]} />
      </div>
    </section>
  )}

  {/* ---------------- Events teaser ---------------- */}
  {events.length > 0 && (
    <section class:list={['band', testimonials.length > 0 ? 'band--blush' : '']}>
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">From the events library</p>
          <h2>Recitals & showcases</h2>
        </div>
        <div class="grid grid--3">
          {events.map((ev, i) => (
            <EventCard event={ev} revealDelay={i} />
          ))}
        </div>
        <p class="text-center" style="margin-top: var(--space-6);">
          <a href="/events" class="btn btn--ghost">Browse all events</a>
        </p>
      </div>
    </section>
  )}

  <CtaBand
    heading="Ready for the first step?"
    text="Tell us who's learning — a child, an adult, a family — and we'll suggest the right course, branch and batch."
  />

  {/* Decorative interactive ghungroo strand — homepage only */}
  <GhungrooStrand />
</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: min(92svh, 56rem);
    background:
      linear-gradient(165deg, var(--white) 0%, var(--blush) 58%, #f9e3e0 100%);
    overflow: hidden;
  }

  .hero--media {
    background: var(--ink);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__bg :global(img) {
    width: 100%;
    height: 100% !important;
    object-fit: cover;
    aspect-ratio: auto !important;
  }

  .hero--media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.25), rgba(26, 26, 26, 0.62));
  }

  .hero__motif {
    position: absolute;
    right: -6rem;
    top: 50%;
    transform: translateY(-50%);
    width: min(34rem, 60vw);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    padding-block: var(--space-8);
  }

  .hero__eyebrow {
    font-size: var(--text-sm);
    letter-spacing: 0.5em;
    color: var(--coral-deep);
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-size: var(--text-hero);
    font-weight: 600;
    max-width: 11ch;
    margin-bottom: var(--space-4);
  }

  .hero__title .brand {
    font-weight: 500;
  }

  .hero__sub {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    max-width: 44ch;
    margin-bottom: var(--space-6);
  }

  .hero--media .hero__title,
  .hero--media .hero__sub,
  .hero--media .hero__eyebrow {
    color: var(--white);
  }

  .hero--media .hero__title .brand {
    color: var(--coral);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ---------- Trust strip ---------- */
  .band--trust {
    padding-block: var(--space-7);
    border-bottom: 1px solid var(--line);
  }

  /* ---------- Intro ---------- */
  .intro-text {
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .home-intro {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 860px) {
    .home-intro {
      grid-template-columns: 42% 1fr;
      gap: var(--space-8);
    }
  }

  .home-intro__media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 26rem;
  }

  @media (max-width: 859px) {
    .home-intro__media {
      margin-inline: auto;
    }
  }

  /* ---------- Disciplines ---------- */
  .discipline-card {
    display: block;
    text-decoration: none;
    color: var(--ink);
  }

  .discipline-card__media {
    overflow: hidden;
  }

  .discipline-card__discipline {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--coral-deep);
    margin-bottom: var(--space-1);
  }

  .discipline-card h3 {
    margin-bottom: var(--space-2);
  }

  .discipline-card__blurb {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---------- Accomplishments teaser ---------- */
  .acc-teaser {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 860px) {
    .acc-teaser {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .acc-teaser__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .acc-teaser__list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--blush);
    border-radius: var(--radius-lg);
  }

  .acc-teaser__value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--coral-deep);
    min-width: 3.2rem;
    text-align: center;
  }
</style>
